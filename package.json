{
  "name": "habit-expense-keeper-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API for Habit Expense Keeper",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
