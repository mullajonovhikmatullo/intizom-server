generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum HabitType {
  good
  bad
}

enum ExpenseCategory {
  food
  transport
  shopping
  bills
  entertainment
  health
  education
  other
}

enum TodoPriority {
  low
  medium
  high
}

enum DebtDirection {
  borrowed
  lent
}

model User {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(120)
  email        String   @unique @db.VarChar(255)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  habits   Habit[]
  expenses Expense[]
  todos    Todo[]
  debts    Debt[]
  loans    Loan[]

  @@index([email])
}

model Habit {
  id         String    @id @default(cuid())
  userId     String
  title      String    @db.VarChar(160)
  time       String?   @db.VarChar(5)
  type       HabitType
  targetDays Int       @default(90)
  pinned     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId])
  @@index([userId, type])
  @@index([userId, createdAt])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime @db.Date
  completed Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([date])
  @@index([habitId, date])
}

model Expense {
  id        String          @id @default(cuid())
  userId    String
  title     String          @db.VarChar(160)
  amount    Decimal         @db.Decimal(12, 2)
  currency  String          @db.VarChar(16)
  category  ExpenseCategory
  date      DateTime        @db.Date
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, date, category])
}

model Todo {
  id          String       @id @default(cuid())
  userId      String
  title       String       @db.VarChar(180)
  note        String?
  priority    TodoPriority @default(medium)
  dueDate     DateTime?    @db.Date
  isDone      Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDone])
  @@index([userId, dueDate])
  @@index([userId, priority])
}

model Debt {
  id        String        @id @default(cuid())
  userId    String
  direction DebtDirection
  person    String        @db.VarChar(160)
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @db.VarChar(16)
  dueDate   DateTime?     @db.Date
  note      String?
  isPaid    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments DebtPayment[]

  @@index([userId])
  @@index([userId, direction])
  @@index([userId, isPaid])
  @@index([userId, dueDate])
}

model DebtPayment {
  id        String   @id @default(cuid())
  debtId    String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId, date])
}

model Loan {
  id            String           @id @default(cuid())
  userId        String
  title         String           @db.VarChar(180)
  totalMonths   Int
  monthlyPayment Decimal         @db.Decimal(12, 2)
  paymentDay    Int
  currency      String          @db.VarChar(16)
  startDate     DateTime        @db.Date
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments LoanInstallment[]

  @@index([userId])
  @@index([userId, createdAt])
}

model LoanInstallment {
  id        String   @id @default(cuid())
  loanId    String
  index     Int
  dueDate   DateTime @db.Date
  paid      Boolean  @default(false)
  paidDate  DateTime? @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([loanId, index])
  @@index([loanId, dueDate])
  @@index([loanId, paid])
}
